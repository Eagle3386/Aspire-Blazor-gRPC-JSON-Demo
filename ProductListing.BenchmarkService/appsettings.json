{
  "AllowedHosts": "*",
  "Kestrel": {
    "EndpointDefaults": {
      // TODO: Remove below after https://github.com/dotnet/aspnetcore/blob/main/src/Servers/Kestrel/Core/src/ListenOptions.cs#L19
      //       includes HTTP/3 to enable it by default.
      //       Enumeration style is in accordance with https://github.com/dotnet/aspnetcore/pull/58328#issuecomment-2403604287.
      "Protocols": "Http2", // gRPC ensures HTTP/2 as minimum by itself.
      "SslProtocols": [ "Tls12", "Tls13" ]
    },
    "Certificates": {
      "Default": {
        "AllowInvalid": true,
        "Location": "CurrentUser",
        "Store": "My",
        "Subject": "localhost"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
